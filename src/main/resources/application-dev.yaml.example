spring:
  devtools:
    restart:
      exclude: db/migration/**
  datasource:
    url: jdbc:postgresql://localhost:5432/theelderforge
    username:
    password:
server:
  servlet:
    session:
      timeout: 30m
      cookie:
        http-only: true
        same-site: lax
        secure: false

app:
  security:
    allowed-origins:
      - http://localhost:3000
